# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit secrets
.env
.env.*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated prisma client (regenerated via `npx prisma generate`)
/generated/

# database journal & old backups
prisma/dev.db-journal
prisma/previous_db/

# user-uploaded media (261MB+ — deploy separately or use cloud storage)
public/uploads/

# scratch / working notes (not part of the codebase)
pageData_block.txt
tmp_segment.txt
tgdc_working.txt
static_pages_content.txt
